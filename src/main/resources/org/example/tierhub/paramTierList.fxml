<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.StackPane?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="401.0" prefWidth="535.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tierhub.ControlleurParamTierlist">
   <children>
      <Button layoutX="285.0" layoutY="344.0" mnemonicParsing="false" onAction="#quitter" prefHeight="30.0" prefWidth="200.0" text="Sauvegarder" />
      <Label layoutX="26.0" layoutY="100.0" prefHeight="26.0" prefWidth="190.0" text="Lien de l'image du Logo :" />
      <ScrollPane fitToHeight="true" fitToWidth="true" layoutX="26.0" layoutY="126.0">
         <content>
            <TextField fx:id="imageLink" prefHeight="26.0" prefWidth="457.0" promptText="https://tiershub.fr/image.png" />
         </content>
      </ScrollPane>
      <Button layoutX="26.0" layoutY="180.0" mnemonicParsing="false" onAction="#chargerImage" prefHeight="26.0" prefWidth="118.0" text="Charger" />
      <StackPane layoutX="26.0" layoutY="221.0" prefHeight="150.0" prefWidth="150.0" style="-fx-border-color: black;">
         <children>
            <ImageView fx:id="imagePreview" fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true" />
         </children>
      </StackPane>
      <Label fx:id="erreurTxt" layoutX="227.0" layoutY="221.0" prefHeight="23.0" prefWidth="271.0" text="ERREUR" textFill="RED" />
      <Button layoutX="305.0" layoutY="180.0" mnemonicParsing="false" onAction="#chargerExplorateur" prefHeight="26.0" prefWidth="179.0" text="Ouvrir l'explorateur de fichier" />
      <Label layoutX="26.0" layoutY="23.0" prefHeight="26.0" prefWidth="190.0" text="Nom de la TierList" />
      <TextField fx:id="nom" layoutX="26.0" layoutY="49.0" prefHeight="26.0" prefWidth="457.0" promptText="Ma tierList trop cool" />
   </children>
</AnchorPane>
